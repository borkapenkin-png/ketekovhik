[Unit]
Description=Ketekohvik backend
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/ketekovhik/backend
EnvironmentFile=/var/www/ketekovhik/backend/.env
ExecStart=/usr/bin/env uvicorn server:app --host 127.0.0.1 --port 8101
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
